<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <% if !dev_mode { %>
    <link rel="stylesheet" href="<%= asset_url %>/assets/app.css">
    <% } %>
</head>
<body>
    <div id="app"></div>
    <script data-page="app" type="application/json"><%- page_json %></script>
    <script type="module" src="<%= asset_url %>/ui/main.ts"></script>
</body>
</html>
