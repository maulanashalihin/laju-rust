<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Laju Rust</title>
    <script>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (stored === 'dark' || (stored === null && prefersDark)) {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
    </script>
    <% if !dev_mode { %>
    <link rel="stylesheet" href="<%= asset_url %>/assets/app.css">
    <% } %>
    <style>
      @keyframes needle-sweep {
        0% { transform: rotate(-90deg); }
        100% { transform: rotate(50deg); }
      }
      .needle { transform-origin: 140px 140px; animation: needle-sweep 1.5s cubic-bezier(0.16,1,0.3,1) both; }
      @keyframes flow-x {
        0% { left: 0; opacity: 0; }
        10% { opacity: 1; }
        90% { opacity: 1; }
        100% { left: calc(100% - 6px); opacity: 0; }
      }
      @keyframes pulse-slow { 0%,100% { opacity: 1; } 50% { opacity: 0.45; } }
      @keyframes ping {
        75%, 100% { transform: scale(2); opacity: 0; }
      }
    </style>
</head>
<body class="min-h-screen bg-stone-50 text-stone-900 antialiased dark:bg-stone-950 dark:text-stone-100">
  <div class="min-h-screen flex flex-col">
    <!-- Navbar -->
    <header class="sticky top-0 z-40 w-full border-b border-stone-200/80 dark:border-stone-800/80 backdrop-blur supports-[backdrop-filter]:bg-white/70 dark:supports-[backdrop-filter]:bg-stone-950/70">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between">
          <div class="flex items-center gap-8">
            <a href="/" class="flex items-center gap-2.5" aria-label="Laju Rust home">
              <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-gradient-to-br from-orange-500 via-amber-500 to-yellow-400 shadow-sm shadow-amber-500/20" aria-hidden="true">
                <svg viewBox="0 0 24 24" class="w-4 h-4 text-white" fill="currentColor"><path d="M13 2L4 14h7l-2 8 9-12h-7l2-8z"/></svg>
              </span>
              <span class="text-base font-semibold tracking-tight bg-gradient-to-r from-orange-600 via-amber-500 to-yellow-500 bg-clip-text text-transparent dark:from-amber-400 dark:via-orange-400 dark:to-yellow-300">Laju Rust</span>
            </a>
            <nav class="flex items-center gap-1" aria-label="Primary">
              <a href="/" class="px-3 py-2 text-sm font-medium rounded-lg transition-colors text-stone-900 dark:text-white bg-stone-100 dark:bg-stone-800/60">Home</a>
              <a href="/about" class="px-3 py-2 text-sm font-medium rounded-lg transition-colors text-stone-600 dark:text-stone-400 hover:text-stone-900 dark:hover:text-white hover:bg-stone-100/60 dark:hover:bg-stone-800/40">About</a>
            </nav>
          </div>
        </div>
      </div>
    </header>

    <!-- Hero -->
    <section class="relative min-h-[90vh] flex flex-col items-center justify-center pt-20 pb-16 text-center overflow-hidden">
      <div class="relative max-w-3xl mx-auto px-4">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/30 text-emerald-700 dark:text-emerald-400 text-xs font-mono uppercase tracking-wider mb-6">
          <span class="relative flex h-1.5 w-1.5"><span class="absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75" style="animation: ping 1s cubic-bezier(0,0,.2,1) infinite"></span><span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-emerald-500"></span></span>
          Performance-First Boilerplate
        </div>
        <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight text-balance">
          Built for <span class="bg-gradient-to-r from-orange-600 via-amber-500 to-yellow-400 bg-clip-text text-transparent dark:from-orange-500 dark:via-amber-400 dark:to-yellow-300">speed</span>.
        </h1>
        <p class="mt-6 text-lg sm:text-xl text-stone-600 dark:text-stone-300 max-w-2xl mx-auto text-pretty"><%= description %></p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href="/register" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg bg-amber-600 hover:bg-amber-500 text-white text-sm font-semibold transition-all shadow-md shadow-amber-500/20 hover:shadow-lg hover:shadow-amber-500/30 active:scale-[0.98]">
            Get started
            <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/about" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-lg bg-stone-100 dark:bg-stone-900 hover:bg-stone-200 dark:hover:bg-stone-800 text-stone-900 dark:text-stone-100 text-sm font-semibold transition-all border border-stone-200 dark:border-stone-800">
            Read the docs
            <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
          </a>
        </div>

        <!-- Speedometer -->
        <div class="mt-16 flex justify-center">
          <div class="relative inline-block">
            <svg viewBox="0 0 280 160" class="w-72 sm:w-80 h-auto" aria-label="Performance speedometer">
              <path d="M 20 140 A 120 120 0 0 1 260 140" fill="none" stroke="currentColor" stroke-width="14" stroke-linecap="round" class="text-stone-200 dark:text-stone-800"/>
              <path d="M 20 140 A 120 120 0 0 1 240 60" fill="none" stroke="url(#gg)" stroke-width="14" stroke-linecap="round"/>
              <g class="text-stone-400 dark:text-stone-600">
                <line x1="20" y1="140" x2="28" y2="132" stroke="currentColor" stroke-width="2"/>
                <line x1="80" y1="44" x2="84" y2="54" stroke="currentColor" stroke-width="2"/>
                <line x1="140" y1="20" x2="140" y2="32" stroke="currentColor" stroke-width="2"/>
                <line x1="200" y1="44" x2="196" y2="54" stroke="currentColor" stroke-width="2"/>
                <line x1="260" y1="140" x2="252" y2="132" stroke="currentColor" stroke-width="2"/>
              </g>
              <g class="needle"><line x1="140" y1="140" x2="140" y2="55" stroke="currentColor" stroke-width="3" stroke-linecap="round" class="text-amber-500 dark:text-amber-400" style="filter:drop-shadow(0 0 8px rgba(251,191,36,0.5))"/></g>
              <circle cx="140" cy="140" r="8" fill="currentColor" class="text-amber-500 dark:text-amber-400"/>
              <circle cx="140" cy="140" r="3" fill="currentColor" class="text-stone-950"/>
              <defs><linearGradient id="gg" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#f59e0b"/><stop offset="100%" stop-color="#fb923c"/></linearGradient></defs>
            </svg>
            <div class="absolute -top-2 right-0 flex items-center gap-1.5 px-2 py-1 rounded-full bg-stone-950/80 backdrop-blur border border-emerald-500/30">
              <span class="relative flex h-1.5 w-1.5"><span class="absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75" style="animation: ping 1s cubic-bezier(0,0,.2,1) infinite"></span><span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-emerald-500"></span></span>
              <span class="text-[10px] font-mono uppercase tracking-wider text-emerald-400">Live</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="max-w-4xl mx-auto w-full px-4 sm:px-6 lg:px-8 pb-24">
      <div class="text-center mb-8">
        <p class="text-xs font-mono uppercase tracking-wider text-amber-600 dark:text-amber-400">Benchmarks</p>
        <h2 class="mt-2 text-3xl sm:text-4xl font-bold tracking-tight text-stone-900 dark:text-stone-100 text-balance">Numbers don't lie</h2>
        <p class="mt-3 text-base text-stone-600 dark:text-stone-300 max-w-2xl mx-auto">Real metrics from a stock Laju Rust build.</p>
      </div>
      <div class="grid grid-cols-2 gap-3 sm:gap-4">
        <div class="rounded-2xl border border-stone-200 dark:border-stone-800 bg-white dark:bg-stone-900/60 p-5 sm:p-6">
          <p class="text-xs font-mono uppercase tracking-wider text-amber-600 dark:text-amber-400">Total Ops/s</p>
          <p class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight text-stone-900 dark:text-stone-100 tabular-nums">17.1M</p>
          <p class="mt-1 text-xs text-stone-500 dark:text-stone-400">aggregate all workloads</p>
        </div>
        <div class="rounded-2xl border border-stone-200 dark:border-stone-800 bg-white dark:bg-stone-900/60 p-5 sm:p-6">
          <p class="text-xs font-mono uppercase tracking-wider text-amber-600 dark:text-amber-400">Random Read</p>
          <p class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight text-stone-900 dark:text-stone-100 tabular-nums">953K</p>
          <p class="mt-1 text-xs text-stone-500 dark:text-stone-400">ops/s at 100B</p>
        </div>
        <div class="rounded-2xl border border-stone-200 dark:border-stone-800 bg-white dark:bg-stone-900/60 p-5 sm:p-6">
          <p class="text-xs font-mono uppercase tracking-wider text-amber-600 dark:text-amber-400">Scan</p>
          <p class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight text-stone-900 dark:text-stone-100 tabular-nums">5.9M</p>
          <p class="mt-1 text-xs text-stone-500 dark:text-stone-400">ops/s at 100B</p>
        </div>
        <div class="rounded-2xl border border-stone-200 dark:border-stone-800 bg-white dark:bg-stone-900/60 p-5 sm:p-6">
          <p class="text-xs font-mono uppercase tracking-wider text-amber-600 dark:text-amber-400">Mixed R/W</p>
          <p class="mt-3 text-3xl sm:text-4xl font-bold tracking-tight text-stone-900 dark:text-stone-100 tabular-nums">333K</p>
          <p class="mt-1 text-xs text-stone-500 dark:text-stone-400">ops/s 45/45/10</p>
        </div>
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="max-w-5xl mx-auto w-full px-4 sm:px-6 lg:px-8 pb-24">
      <div class="text-center mb-8">
        <p class="text-xs font-mono uppercase tracking-wider text-amber-600 dark:text-amber-400">Stack</p>
        <h2 class="mt-2 text-3xl sm:text-4xl font-bold tracking-tight text-stone-900 dark:text-stone-100 text-balance">Every layer, deliberately chosen</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4">
        <% let items = ["Axum","Sailfish","RocksDB","Inertia.js v3","Svelte 5","Vite 8","Tailwind CSS 4"]; %>
        <% for name in items { %>
        <div class="rounded-2xl border border-stone-200 dark:border-stone-800 bg-white dark:bg-stone-900/60 p-5 sm:p-6 transition-all hover:border-amber-500/50 hover:shadow-lg hover:shadow-amber-500/5 hover:-translate-y-0.5">
          <div class="w-10 h-10 rounded-lg bg-amber-500/10 flex items-center justify-center text-amber-600 dark:text-amber-400 font-mono font-bold text-xs mb-3"><%= name.chars().take(2).collect::<String>() %></div>
          <p class="font-semibold text-sm text-stone-900 dark:text-stone-100"><%= name %></p>
        </div>
        <% } %>
      </div>
    </section>

    <!-- Terminal -->
    <section class="max-w-3xl mx-auto w-full px-4 sm:px-6 lg:px-8 pb-24">
      <div class="text-center mb-8">
        <p class="text-xs font-mono uppercase tracking-wider text-amber-600 dark:text-amber-400">Quickstart</p>
        <h2 class="mt-2 text-3xl sm:text-4xl font-bold tracking-tight text-stone-900 dark:text-stone-100 text-balance">From zero to running in 30 seconds</h2>
      </div>
      <div class="rounded-2xl border border-stone-800 bg-stone-950 overflow-hidden shadow-2xl shadow-amber-500/5">
        <div class="flex items-center gap-2 px-4 py-3 border-b border-stone-800 bg-stone-900/60">
          <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
          <span class="w-3 h-3 rounded-full bg-emerald-500/80"></span>
          <span class="ml-3 text-xs font-mono text-stone-500">zsh — laju-rust</span>
        </div>
        <div class="p-5 sm:p-6 font-mono text-sm space-y-1.5 min-h-[200px]">
          <div class="text-stone-300"><span class="text-amber-400">$</span><span class="text-cyan-400"> npx</span><span class="text-stone-100"> create-laju-rust</span><span class="text-amber-300"> my-app</span></div>
          <div class="text-stone-400"><span class="text-emerald-400">*</span> Checking Rust toolchain...</div>
          <div class="text-stone-400"><span class="text-emerald-400">*</span> Scaffolding project structure...</div>
          <div class="text-stone-400"><span class="text-emerald-400">*</span> Installing dependencies...</div>
          <div class="text-stone-400"><span class="text-emerald-400">*</span> Configuring Vite + Tailwind 4...</div>
          <div class="text-stone-400"><span class="text-emerald-400">*</span> Seeding RocksDB defaults...</div>
          <div class="text-emerald-400">* Done! Run `cd my-app && cargo run`</div>
          <div class="text-stone-500 mt-3"><span class="text-amber-400">$</span> <span class="inline-block w-2 h-4 bg-amber-400 align-middle" style="animation: pulse-slow 1s step-end infinite"></span></div>
        </div>
      </div>
    </section>

    <!-- Architecture -->
    <section class="max-w-5xl mx-auto w-full px-4 sm:px-6 lg:px-8 pb-24">
      <div class="text-center mb-10">
        <p class="text-xs font-mono uppercase tracking-wider text-amber-600 dark:text-amber-400">Architecture</p>
        <h2 class="mt-2 text-3xl sm:text-4xl font-bold tracking-tight text-stone-900 dark:text-stone-100 text-balance">How a request flows</h2>
        <p class="mt-3 text-base text-stone-600 dark:text-stone-300 max-w-2xl mx-auto">Five layers, one direction, zero ceremony.</p>
      </div>
      <div class="rounded-2xl border border-stone-200 dark:border-stone-800 bg-white dark:bg-stone-900/60 p-6 sm:p-8">
        <div class="flex flex-col lg:flex-row items-stretch lg:items-center gap-4 lg:gap-0">
          <div class="flex-1 flex flex-col items-center text-center min-w-0">
            <div class="w-12 h-12 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center text-amber-600 dark:text-amber-400 mb-3">
              <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            </div>
            <p class="text-[10px] font-mono uppercase tracking-wider text-stone-500 dark:text-stone-500">Client</p>
            <p class="text-sm font-semibold text-stone-900 dark:text-stone-100 mt-0.5">Browser</p>
            <p class="text-xs text-stone-500 dark:text-stone-400 mt-0.5">Window to the app</p>
          </div>
          <div class="hidden lg:block flex-1 h-px bg-gradient-to-r from-stone-700 via-stone-600 to-stone-700 mx-2 self-center relative overflow-hidden"></div>
          <div class="lg:hidden h-px w-12 mx-auto bg-stone-300 dark:bg-stone-700"></div>
          <% let layers = [ ("Frontend","Svelte 5","Reactive UI"), ("Adapter","Inertia.js","Server-driven SPA"), ("Backend","Axum","Async routing"), ("Storage","RocksDB","Embedded KV") ]; for (role, name, desc) in layers { %>
          <div class="flex-col lg:flex-row items-center gap-4 lg:gap-0 hidden lg:flex"></div>
          <div class="hidden lg:block flex-1 h-px bg-gradient-to-r from-stone-700 via-stone-600 to-stone-700 mx-2 self-center relative overflow-hidden"></div>
          <div class="flex-1 flex flex-col items-center text-center min-w-0">
            <div class="w-12 h-12 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center text-amber-600 dark:text-amber-400 mb-3">
              <svg viewBox="0 0 24 24" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2"><% if role == "Frontend" { %><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/><% } else if role == "Adapter" { %><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/><% } else if role == "Backend" { %><rect x="2" y="3" width="20" height="8" rx="2"/><rect x="2" y="13" width="20" height="8" rx="2"/><path d="M6 7h.01"/><path d="M6 17h.01"/><% } else { %><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14a9 3 0 0 0 18 0V5"/><path d="M3 12a9 3 0 0 0 18 0"/><% } %></svg>
            </div>
            <p class="text-[10px] font-mono uppercase tracking-wider text-stone-500 dark:text-stone-500"><%= role %></p>
            <p class="text-sm font-semibold text-stone-900 dark:text-stone-100 mt-0.5"><%= name %></p>
            <p class="text-xs text-stone-500 dark:text-stone-400 mt-0.5"><%= desc %></p>
          </div>
          <% } %>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="max-w-4xl mx-auto w-full px-4 sm:px-6 lg:px-8 pb-24">
      <div class="relative rounded-3xl bg-gradient-to-br from-stone-900 to-stone-950 border border-stone-800 p-8 sm:p-12 text-center overflow-hidden">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-stone-100 text-balance">Ready to ship at the speed of Rust?</h2>
        <div class="mt-6 inline-flex items-center gap-2 px-4 py-2.5 rounded-lg bg-stone-950/80 border border-stone-800 font-mono text-sm">
          <span class="text-amber-400">$</span><span class="text-cyan-400">npx</span><span class="text-stone-100">create-laju-rust</span><span class="text-amber-300">my-app</span>
        </div>
        <div class="mt-8">
          <a href="/register" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-amber-600 hover:bg-amber-500 text-white text-sm font-semibold transition-all shadow-lg shadow-amber-500/30 hover:shadow-xl hover:shadow-amber-500/40 active:scale-[0.98]">
            Create your account
            <svg viewBox="0 0 24 24" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-stone-200 dark:border-stone-800 py-8 mt-auto">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-3">
          <div class="flex items-center gap-2.5">
            <span class="inline-flex items-center justify-center w-6 h-6 rounded-md bg-gradient-to-br from-orange-500 via-amber-500 to-yellow-400" aria-hidden="true">
              <svg viewBox="0 0 24 24" class="w-3 h-3 text-white" fill="currentColor"><path d="M13 2L4 14h7l-2 8 9-12h-7l2-8z"/></svg>
            </span>
            <span class="text-sm font-medium text-stone-700 dark:text-stone-300">Laju Rust</span>
          </div>
          <p class="text-sm text-stone-500 dark:text-stone-400 text-center sm:text-right">Built with Axum + Inertia.js + Svelte 5 + Tailwind CSS 4</p>
        </div>
      </div>
    </footer>
  </div>

  <% if dev_mode { %>
  <script type="module" src="<%= asset_url %>/ui/main.ts"></script>
  <% } %>
</body>
</html>
