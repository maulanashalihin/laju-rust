# Database backend: "rocksdb" (default) atau "sqlite"
DB_BACKEND=rocksdb

# Path ke database (RocksDB: folder, SQLite: file path)
DB_PATH=data/rocksdb

# Server listen address
SERVER_ADDR=0.0.0.0:3000

# Development mode (true = hot-reload, false = production)
DEV_MODE=true

# Vite dev server URL (hanya dipakai kalo DEV_MODE=true)
VITE_DEV_URL=http://localhost:5173
